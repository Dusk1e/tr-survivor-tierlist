# =====================================================================
#  TR - SURVİVOR TİERLİST — Environment configuration
# =====================================================================
#  Copy this file to ".env.local" and fill in your values.
#  Everything here is OPTIONAL — the app runs out of the box in
#  "Local Demo Mode" (data saved in the browser via localStorage).
#  Add the Supabase keys below to switch to a real, shared database.
# =====================================================================

# ---- Admin login --------------------------------------------------
# Password the admin uses to unlock the dashboard at /admin.
# If you leave this unset, the demo password is:  survivor2024
ADMIN_PASSWORD=survivor2024

# Secret used to sign the admin session cookie. Use a long random string.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=change-me-to-a-long-random-string

# ---- Supabase (optional — enables a real shared database) ---------
# Create a project at https://supabase.com, then run supabase/schema.sql
# in the SQL editor. Paste your keys below.
#
# Public (safe to expose to the browser):
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
#
# Server-only (NEVER expose to the browser). Used for admin writes:
SUPABASE_SERVICE_ROLE_KEY=
